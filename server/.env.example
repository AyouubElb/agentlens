# Copy to .env and fill in. Never commit .env.
# DATABASE_URL: Supabase direct connection (port 5432, NOT the pooled 6543 URL — Prisma migrations
# need the direct connection).
DATABASE_URL="postgresql://user:password@localhost:5432/agentlens?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="2h"
PORT=8000
CORS_ORIGIN="http://localhost:5173"
