datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
  runtime      = "nodejs"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String
  passwordHash String
  createdAt    DateTime @default(now())
}

