                  },
                  "username": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 50
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 200,
                    "allOf": [
                      {
                        "type": "string",
                        "pattern": "[a-z]"
                      },
                      {
                        "type": "string",
                        "pattern": "[A-Z]"
                      },
                      {
                        "type": "string",
                        "pattern": "[0-9]"
                      }
                    ]
                  }
                },
                "required": [
                  "email",
                  "username",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "username": {
                      "type": "string"
                    },
                    "createdAt": {
                      "type": "string",
                      "format": "date-time"
                    }
                  },
                  "required": [
                    "id",
                    "email",
                    "username",
                    "createdAt"
